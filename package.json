{
	"name": "tonguetoquill-web",
	"private": true,
	"version": "0.1.2",
	"type": "module",
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"dev": "node --env-file=.env.dev ./node_modules/.bin/vite dev --mode dev",
		"dev:mock": "node --env-file=.env.dev --env-file=.env.mock ./node_modules/.bin/vite dev --mode mock",
		"build": "vite build",
		"preview": "vite preview --mode dev",
		"prepare": "husky || true",
		"pack": "npm run pack:quills && npm run pack:templates",
		"pack:quills": "node scripts/package-quills.js",
		"pack:templates": "node scripts/package-templates.js",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:deployment": "node scripts/check-deployment.js",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test": "npm run test:unit && npm run test:browser && npm run test:e2e",
		"test:unit": "vitest run --project=server",
		"test:browser": "vitest run --project=client",
		"test:e2e": "playwright test",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"db:migrate": "drizzle-kit migrate",
		"release": "echo 'Releases are triggered via GitHub Actions workflow_dispatch. Go to Actions → Prepare release.' && exit 1"
	},
	"devDependencies": {
		"@airmark/quiver": "^0.15.0",
		"@eslint/compat": "^1.4.0",
		"@eslint/js": "^9.36.0",
		"@neondatabase/serverless": "^1.0.2",
		"@playwright/test": "^1.55.1",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-node": "^5.4.0",
		"@sveltejs/adapter-vercel": "^6.2.0",
		"@sveltejs/kit": "^2.56.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.0",
		"@tailwindcss/vite": "^4.1.13",
		"@types/node": "^22",
		"@types/node-cron": "^3.0.11",
		"@types/pg": "^8.16.0",
		"@types/uuid": "^10.0.0",
		"@vercel/analytics": "^1.6.1",
		"@vercel/speed-insights": "^2.0.0",
		"@vitest/browser": "^3.2.4",
		"dotenv": "^17.2.3",
		"drizzle-kit": "^0.31.10",
		"eslint": "^9.36.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.12.4",
		"globals": "^16.4.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.6",
		"playwright": "^1.55.1",
		"prettier": "^3.3.3",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.6.14",
		"svelte": "^5.39.5",
		"svelte-check": "^4.3.2",
		"tailwindcss": "^4.1.13",
		"typescript": "^5.9.2",
		"typescript-eslint": "^8.44.1",
		"vite": "^7.1.7",
		"vite-plugin-wasm": "^3.5.0",
		"vitest": "^3.2.4",
		"vitest-browser-svelte": "^1.1.0"
	},
	"dependencies": {
		"@auth/drizzle-adapter": "^1.11.1",
		"@auth/sveltekit": "^1.11.1",
		"@codemirror/commands": "^6.10.0",
		"@codemirror/lang-markdown": "^6.5.0",
		"@codemirror/language": "^6.11.3",
		"@codemirror/state": "^6.5.2",
		"@codemirror/theme-one-dark": "^6.1.3",
		"@codemirror/view": "^6.38.6",
		"@electric-sql/pglite": "^0.3.14",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@quillmark/quiver": "^0.7.0",
		"@quillmark/wasm": "0.75.0",
		"@toon-format/toon": "^2.1.0",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.1",
		"lucide-svelte": "^0.548.0",
		"node-cron": "^4.2.1",
		"pg": "^8.16.3",
		"prosemirror-commands": "^1.7.1",
		"prosemirror-dropcursor": "^1.8.2",
		"prosemirror-gapcursor": "^1.4.0",
		"prosemirror-history": "^1.5.0",
		"prosemirror-inputrules": "^1.5.1",
		"prosemirror-keymap": "^1.2.3",
		"prosemirror-markdown": "^1.13.2",
		"prosemirror-model": "^1.25.4",
		"prosemirror-schema-list": "^1.5.1",
		"prosemirror-state": "^1.4.4",
		"prosemirror-tables": "^1.8.5",
		"prosemirror-transform": "^1.10.5",
		"prosemirror-view": "^1.41.4",
		"shadcn-svelte": "^1.0.10",
		"tailwind-merge": "^3.3.1",
		"uuid": "^14.0.0",
		"yaml": "^2.8.2",
		"zod": "^4.1.12"
	},
	"overrides": {
		"cookie": "^0.7.0"
	},
	"lint-staged": {
		"*.{js,ts,svelte}": [
			"prettier --write"
		],
		"*.{json,md,css,html}": [
			"prettier --write"
		]
	}
}
