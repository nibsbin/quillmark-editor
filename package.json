{
  "name": "@quillmark/editor",
  "version": "0.1.0",
  "description": "Lexical-based rich-text editor for QuillMark documents — Svelte components, headless core, and a self-contained custom element.",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "svelte": "./dist/svelte/index.js",
      "types": "./dist/svelte/index.d.ts",
      "import": "./dist/svelte/index.js"
    },
    "./element": {
      "types": "./dist/element/index.d.ts",
      "import": "./dist/element/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build": "npm run build:core && npm run build:svelte && npm run build:element && npm run build:styles && npm run build:cleanup",
    "build:core": "vite build --config vite.core.config.ts",
    "build:svelte": "svelte-package -i src/svelte -o dist/svelte --tsconfig ./tsconfig.json",
    "build:element": "vite build --config vite.element.config.ts",
    "build:styles": "node scripts/copy-styles.mjs",
    "build:cleanup": "node scripts/cleanup-src-types.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "size": "node scripts/check-size.mjs"
  },
  "peerDependencies": {
    "@quillmark/wasm": "^0.67.0",
    "svelte": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "svelte": {
      "optional": true
    }
  },
  "dependencies": {
    "@lexical/code": "^0.21.0",
    "@lexical/history": "^0.21.0",
    "@lexical/link": "^0.21.0",
    "@lexical/list": "^0.21.0",
    "@lexical/markdown": "^0.21.0",
    "@lexical/rich-text": "^0.21.0",
    "@lexical/selection": "^0.21.0",
    "@lexical/table": "^0.21.0",
    "@lexical/utils": "^0.21.0",
    "lexical": "^0.21.0"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tsconfig/svelte": "^5.0.4",
    "@types/node": "^22.10.0",
    "jsdom": "^25.0.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
