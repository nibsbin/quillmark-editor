# Local development — pairs with deployments/dev.yaml
# =======================================================
# CONFIG_PATH selects the deployment YAML. Vite auto-loads this file via
# `--mode dev` (see package.json `dev` script). Brand, auth toggles, feature
# flags, and db driver live in the YAML; this file is only for secrets the
# boot cascade requires (none for mock + pglite + feedback upstream none).
#
# Readiness check:
#   set -a; source .env.dev; set +a
#   node scripts/check-deployment.js deployments/dev.yaml
# =======================================================

CONFIG_PATH=deployments/dev.yaml

# No secrets required for the current dev.yaml (mock auth, pglite, no feedback
# upstream). AUTH_SECRET falls back in code when only mock providers are enabled.

# --- Uncomment if you change dev.yaml (see deployments/README.md) ---
# Real OAuth (set auth.providers.github/google in YAML, then):
# AUTH_SECRET=
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# Neon or Postgres locally (set db.driver: neon or pg in YAML, then):
# DATABASE_URL=
# CRON_SECRET=

# GitHub feedback (set features.feedback.upstream: github in YAML, then):
# FEEDBACK_GITHUB_KEY=

# GitLab feedback (set features.feedback.upstream: gitlab in YAML, then):
# FEEDBACK_GITLAB_KEY=
# FEEDBACK_GITLAB_URL=

CRON_SECRET="asdf"
