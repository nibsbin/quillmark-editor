# DoD / Airmark environment — pairs with deployments/airmark.yaml
# ================================================================
# Copy and fill for local compose or CI-secrets parity:
#   cp .env.dod.example .env.dod
#
# Behavioral knobs (brand, CUI classification, OIDC issuer, GitLab feedback,
# db driver) are in deployments/airmark.yaml. This file supplies secrets
# referenced by deployment/dod/docker-compose.yml (and satisfies the boot
# cascade in src/lib/config/schema.ts).
#
# docker-compose sets CONFIG_PATH (default below), builds DATABASE_URL from
# POSTGRES_PASSWORD, and passes through the auth / cron / feedback secrets.
# ================================================================

# Optional override (compose default is deployments/airmark.yaml)
# CONFIG_PATH=deployments/airmark.yaml

# Database — compose expands this into DATABASE_URL for the app service:
#   postgresql://postgres:${POSTGRES_PASSWORD}@db:5432/tonguetoquill
POSTGRES_PASSWORD="REPLACE_WITH_PASSWORD"

# Auth.js session signing (required when OIDC is enabled — openssl rand -base64 32)
AUTH_SECRET="REPLACE_WITH_32_CHAR_RANDOM_STRING"

# OIDC — names must match auth.providers.oidc.envPrefix in airmark.yaml (AUTH_USAF)
AUTH_USAF_CLIENT_ID="tonguetoquill-web"
AUTH_USAF_CLIENT_SECRET="your-usaf-client-secret-here"

# Cron routes: Authorization: Bearer <CRON_SECRET>
CRON_SECRET="REPLACE_WITH_LONG_RANDOM_SECRET"

# Feedback — airmark.yaml uses features.feedback.upstream: gitlab
FEEDBACK_GITLAB_URL="https://gitlab.example/api/v4/projects/<id-or-encoded-path>"
FEEDBACK_GITLAB_KEY="your-gitlab-pat-here"
